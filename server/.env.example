PORT=8787
PUBLIC_BASE_URL=https://your-domain.example

# amoCRM OAuth app
AMO_CLIENT_ID=00000000-0000-0000-0000-000000000000
AMO_CLIENT_SECRET=replace_me
AMO_REDIRECT_PATH=/oauth/callback

# For simple at-rest encryption of tokens JSON
TOKENS_SECRET=replace_me_with_long_random

# Allowed origins for widget frontend (during dev you can keep "*")
CORS_ORIGIN=*

